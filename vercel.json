{
  "version": 2,
  "rewrites": [
    {
      "source": "src/api/(.*)",
      "destination": "src/api/index.ts"
    }
  ],
  "builds": [
    {
      "src": "src/api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/api/index.ts"
    }
  ]
}
